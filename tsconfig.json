{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "target": "es2016",
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "outDir": "./dist",
    "files": [],
    "references": [
      {
        "path": "./tsconfig.app.json"
      },
      {
        "path": "./tsconfig.node.json"
      }
    ],

  },
  "include": [
    "src/**/*"
  ]
}